{
  "name": "strapi-plugin-ai-seo",
  "version": "1.1.0",
  "description": "AI-powered SEO tag generator for Strapi. Reads yoastHeadJson or SEO component data from entries, generates meta tags, OG tags, Twitter cards, and schema markup using LLM, with copy and apply functionality.",
  "license": "MIT",
  "author": {
    "name": "Nagendra Singh Chauhan",
    "email": "nagendra.chauhan2001@gmail.com",
    "url": "https://github.com/nagendrasingh92"
  },
  "maintainers": [
    {
      "name": "Nagendra Singh Chauhan",
      "email": "nagendra.chauhan2001@gmail.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nagendrasingh92/strapi-plugin-ai-seo"
  },
  "homepage": "https://github.com/nagendrasingh92/strapi-plugin-ai-seo#readme",
  "bugs": {
    "url": "https://github.com/nagendrasingh92/strapi-plugin-ai-seo/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "name": "ai-seo",
    "displayName": "AI SEO",
    "description": "AI-powered SEO tag generator with copy and apply functionality.",
    "kind": "plugin"
  },
  "type": "commonjs",
  "exports": {
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.tsx",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "strapi-server.js",
    "strapi-admin.js"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify"
  },
  "dependencies": {},
  "devDependencies": {
    "@strapi/sdk-plugin": "^6.0.0",
    "@strapi/strapi": "^5.40.0",
    "@strapi/design-system": "^2.0.0-rc.14",
    "@strapi/icons": "^2.0.0-rc.14",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@strapi/strapi": "^5.0.0",
    "@strapi/design-system": "^2.0.0-rc.14",
    "@strapi/icons": "^2.0.0-rc.14",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "keywords": [
    "strapi",
    "plugin",
    "strapi-plugin",
    "seo",
    "ai-seo",
    "meta-tags",
    "og-tags",
    "schema-markup",
    "twitter-card",
    "yoast",
    "llm",
    "ai"
  ]
}
